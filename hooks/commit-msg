#!/bin/bash

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# ==========================================
# CONFIGURAГ‡ГѓO DO REPOSITГ“RIO (AJUSTE AQUI)
# ==========================================
GITHUB_OWNER="AllysonGustavo1"
GITHUB_REPO="nullbank"

# ==========================================
# VERIFICAГ‡ГѓO 1: FORMATO DA MENSAGEM
# ==========================================
# Regex para garantir o padrГЈo: #NUMERO - Mensagem qualquer
REGEX="^#([0-9]+) - .+$"

if [[ ! $COMMIT_MSG =~ $REGEX ]]; then
  echo "================================================================"
  echo "вќЊ ERRO: O commit foi rejeitado!"
  echo "Sua mensagem nГЈo segue o padrГЈo exigido pelo projeto."
  echo "Formato correto: #NUM_ISSUE - MENSAGEM"
  echo "Exemplo vГЎlido : #33 - CorreГ§ГЈo da mensagem da tela principal"
  echo "================================================================"
  exit 1
fi

# Extrai o nГєmero da issue usando o grupo de captura da Regex do Bash
ISSUE_NUM="${BASH_REMATCH[1]}"

# ==========================================
# VERIFICAГ‡ГѓO 2: EXISTГЉNCIA DA ISSUE
# ==========================================
echo "рџ”Ќ Verificando se a issue #$ISSUE_NUM existe no GitHub..."

# Faz uma requisiГ§ГЈo Г  API do GitHub e captura apenas o cГіdigo de status HTTP (ex: 200, 404)
HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" https://api.github.com/repos/$GITHUB_OWNER/$GITHUB_REPO/issues/$ISSUE_NUM)

if [ "$HTTP_STATUS" -eq 200 ]; then
  echo "вњ… ValidaГ§ГЈo concluГ­da: Issue #$ISSUE_NUM encontrada com sucesso!"
  exit 0
elif [ "$HTTP_STATUS" -eq 404 ]; then
  echo "================================================================"
  echo "вќЊ ERRO: O commit foi rejeitado!"
  echo "A issue #$ISSUE_NUM nГЈo existe no repositГіrio $GITHUB_OWNER/$GITHUB_REPO."
  echo "Por favor, verifique o nГєmero da tarefa."
  echo "================================================================"
  exit 1
else
  echo "вљ пёЏ Aviso: NГЈo foi possГ­vel verificar a issue na API do GitHub (Status: $HTTP_STATUS)."
  echo "Para evitar bloqueios indevidos por falha de rede, o commit serГЎ permitido."
  exit 0
fi